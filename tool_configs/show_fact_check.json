                "is_system_provided": false,
                "dynamic_variable": "",
                "constant_value": ""
            },
            "year": {
                "type": "string",
                "description": "The year the fact check was published",
                "is_system_provided": false,
                "dynamic_variable": "",
                "constant_value": ""
            },
            "candidate": {
                "type": "string",
                "description": "The candidate associated with the claim",
                "is_system_provided": false,
                "dynamic_variable": "",
                "constant_value": ""
            }
        }
    },
    "expects_response": false,
    "dynamic_variables": {
        "dynamicVariablePlaceholders": {}
    },
    "execution_mode": "immediate"
}